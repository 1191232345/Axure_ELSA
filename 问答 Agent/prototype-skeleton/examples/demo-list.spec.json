{
  "moduleName": "价卡查询示例",
  "pageId": "demo-list",
  "breadcrumb": "费用管理",
  "pageType": "list-crud",
  "version": "1.0.0",
  "dataFile": "data/demo-list-data.json",
  "filters": [
    {
      "id": "filterStatus",
      "label": "状态",
      "type": "select",
      "field": "status",
      "match": "exact",
      "options": [
        { "value": "", "label": "全部" },
        { "value": "active", "label": "启用" },
        { "value": "inactive", "label": "禁用" }
      ]
    },
    {
      "id": "filterKeyword",
      "label": "价卡名称",
      "type": "text",
      "field": "name",
      "match": "contains",
      "placeholder": "输入关键字"
    }
  ],
  "columns": [
    { "field": "name", "label": "价卡名称" },
    { "field": "customer", "label": "客户" },
    { "field": "status", "label": "状态", "type": "status" },
    { "field": "createdAt", "label": "创建时间", "type": "datetime" }
  ],
  "rowActions": ["edit", "delete"],
  "toolbarButtons": [
    { "id": "addBtn", "label": "新增价卡", "icon": "fa-plus", "action": "create", "variant": "primary" }
  ],
  "formFields": [
    {
      "id": "fieldName",
      "label": "价卡名称",
      "field": "name",
      "type": "text",
      "required": true,
      "placeholder": "请输入价卡名称"
    },
    {
      "id": "fieldCustomer",
      "label": "客户",
      "field": "customer",
      "type": "text",
      "required": true
    },
    {
      "id": "fieldStatus",
      "label": "状态",
      "field": "status",
      "type": "select",
      "required": true,
      "options": [
        { "value": "active", "label": "启用" },
        { "value": "inactive", "label": "禁用" }
      ]
    }
  ],
  "statusLabels": {
    "active": { "label": "启用", "class": "badge-success" },
    "inactive": { "label": "禁用", "class": "badge-secondary" }
  },
  "mockData": [
    {
      "id": "pc_001",
      "name": "美国仓标准价卡",
      "customer": "示例客户 A",
      "status": "active",
      "createdAt": "2026-06-01T10:00:00.000Z"
    },
    {
      "id": "pc_002",
      "name": "欧洲仓经济价卡",
      "customer": "示例客户 B",
      "status": "inactive",
      "createdAt": "2026-06-15T14:30:00.000Z"
    }
  ],
  "logicDocs": {
    "init": [
      ["列表数据", "加载 mock 数据并渲染表格", "data/demo-list-data.json", "按 createdAt 展示"]
    ],
    "filters": [
      ["状态", "下拉", "精确匹配 status"],
      ["价卡名称", "文本", "模糊匹配 name"]
    ],
    "buttons": [
      ["新增价卡", "工具栏", "无", "打开表单弹窗"],
      ["编辑", "行操作", "无", "打开表单并回填"],
      ["删除", "行操作", "confirm", "从列表移除"]
    ],
    "fields": [
      ["name", "价卡名称", "String", "是", "手工输入"],
      ["customer", "客户", "String", "是", "手工输入"],
      ["status", "状态", "Enum", "是", "active/inactive"]
    ]
  },
  "changelog": {
    "version": "1.0.0",
    "storageKey": "demo_list_changelog_v1",
    "autoShow": true,
    "entries": [
      {
        "version": "v1.0.0",
